<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:title="Project Details"
        app:titleTextColor="?attr/colorOnPrimary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/detName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="24sp"
                android:textStyle="bold"
                android:text="Project Name" />

            <TextView
                android:id="@+id/detCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="@android:color/darker_gray"
                android:text="Code: PRJ001"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Description:"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/detDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Description goes here..."
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Start Date: "
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/detStartDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="01/01/2023" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="End Date: "
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/detEndDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="01/12/2023" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Manager/Owner:"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/detManager"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Manager Name"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Status:"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/detStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Active"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Budget:"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/detBudget"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1000.00"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Special Requirements:"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/detRequirements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="None"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Client/Department:"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/detClient"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="N/A"
                android:layout_marginBottom="24dp" />

            <Button
                android:id="@+id/btnManageExpenses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Manage Expenses"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnUpload"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Upload to Cloud"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>