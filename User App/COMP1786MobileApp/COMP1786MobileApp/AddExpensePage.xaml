<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="COMP1786MobileApp.AddExpensePage"
             Title="Add Project Expense">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Selected project:" FontAttributes="Bold" FontSize="18"/>
            <Label x:Name="ProjectNameLabel" TextColor="RoyalBlue" FontSize="20" Margin="0,0,0,10"/>

            <Label Text="Expense code:" />
            <Entry x:Name="ExpenseCodeEntry" Placeholder="EXP-001" />

            <Label Text="Amount:" />
            <Entry x:Name="AmountEntry" Placeholder="Enter amount" Keyboard="Numeric" />

            <Label Text="Currency:" />
            <Entry x:Name="CurrencyEntry" Placeholder="GBP" Text="GBP" />

            <Label Text="Expense type:" />
            <Picker x:Name="TypePicker" Title="Select type">
                <Picker.Items>
                    <x:String>Travel</x:String>
                    <x:String>Equipment</x:String>
                    <x:String>Food</x:String>
                    <x:String>Others</x:String>
                </Picker.Items>
            </Picker>

            <Label Text="Expense date:" />
            <DatePicker x:Name="ExpenseDatePicker" Format="yyyy-MM-dd" />

            <Label Text="Payment method:" />
            <Picker x:Name="MethodPicker" Title="Select payment method">
                <Picker.Items>
                    <x:String>Cash</x:String>
                    <x:String>Credit Card</x:String>
                    <x:String>Bank Transfer</x:String>
                </Picker.Items>
            </Picker>

            <Label Text="Claimant:" />
            <Entry x:Name="ClaimantEntry" Placeholder="Your name" />

            <Label Text="Payment status:" />
            <Picker x:Name="PaymentStatusPicker" Title="Select status">
                <Picker.Items>
                    <x:String>Pending</x:String>
                    <x:String>Paid</x:String>
                    <x:String>Rejected</x:String>
                </Picker.Items>
            </Picker>

            <Label Text="Location:" />
            <Entry x:Name="LocationEntry" Placeholder="Expense location" />

            <Label Text="Description:" />
            <Editor x:Name="DescriptionEditor" Placeholder="Additional information..." HeightRequest="100" />

            <Button Text="SAVE TO CLOUD" 
                    Clicked="OnSaveClicked" 
                    BackgroundColor="Green" 
                    TextColor="White" 
                    FontAttributes="Bold" 
                    HeightRequest="50"
                    Margin="0,20,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>