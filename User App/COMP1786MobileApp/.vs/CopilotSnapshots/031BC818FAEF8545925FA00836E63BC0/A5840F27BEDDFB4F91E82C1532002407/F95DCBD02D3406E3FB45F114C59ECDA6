<VerticalStackLayout Padding="15" Spacing="10">
    <SearchBar x:Name="searchBar" Placeholder="Search by name/date..." TextChanged="OnSearch" />

    <CollectionView x:Name="projectList" SelectionMode="Single" SelectionChanged="OnProjectSelected">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame Margin="5" Padding="10">
                    <HorizontalStackLayout Spacing="10">
                        <VerticalStackLayout WidthRequest="250">
                            <Label Text="{Binding projectName}" FontAttributes="Bold" />
                            <Label Text="{Binding projectManager}" TextColor="Gray" />
                        </VerticalStackLayout>
                        <Button Text="★" Clicked="OnFavClicked" CommandParameter="{Binding .}" />
                    </HorizontalStackLayout>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</VerticalStackLayout>