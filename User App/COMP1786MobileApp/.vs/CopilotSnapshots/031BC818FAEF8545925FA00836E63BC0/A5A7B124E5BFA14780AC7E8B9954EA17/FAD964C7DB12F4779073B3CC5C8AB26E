using COMP1786MobileApp.Models;
using Firebase.Database;
using Firebase.Database.Query;
using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace COMP1786MobileApp.Services
{
    public class FirebaseService
    {
        private const string BaseUrl = "https://mobileappexpensetracker-default-rtdb.firebaseio.com/";
        private readonly FirebaseClient client = new FirebaseClient(BaseUrl);

        public async Task<List<Project>> GetProjectsAsync()
        {
            try
            {
                var list = await client.Child("projects").OnceAsync<object>();

                if (list == null)
                    return new List<Project>();

                var results = new List<Project>();

                foreach (var item in list)
                {
                    try
                    {
                        // Serialize then deserialize to a dictionary to read arbitrary field names
                        var json = System.Text.Json.JsonSerializer.Serialize(item.Object);
                        var dict = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, System.Text.Json.JsonElement>>(json);

                        var p = new Project();
                        p.Id = item.Key;

                        if (dict != null)
                        {
                            // name -> projectName
                            if (dict.TryGetValue("name", out var nameEl) && nameEl.ValueKind != System.Text.Json.JsonValueKind.Null)
                                p.projectName = nameEl.GetString();
                            else if (dict.TryGetValue("projectName", out var pnameEl) && pnameEl.ValueKind != System.Text.Json.JsonValueKind.Null)
                                p.projectName = pnameEl.GetString();
                            else if (dict.TryGetValue("code", out var codeEl) && codeEl.ValueKind != System.Text.Json.JsonValueKind.Null)
                                p.projectName = codeEl.GetString();

                            // manager -> projectManager
                            if (dict.TryGetValue("manager", out var mgrEl) && mgrEl.ValueKind != System.Text.Json.JsonValueKind.Null)
                                p.projectManager = mgrEl.GetString();
                            else if (dict.TryGetValue("projectManager", out var pmEl) && pmEl.ValueKind != System.Text.Json.JsonValueKind.Null)
                                p.projectManager = pmEl.GetString();

                            // budget -> projectBudget
                            if (dict.TryGetValue("budget", out var budEl) && budEl.ValueKind != System.Text.Json.JsonValueKind.Null)
                            {
                                if (budEl.TryGetDecimal(out var dec))
                                    p.projectBudget = dec;
                                else if (budEl.ValueKind == System.Text.Json.JsonValueKind.Number)
                                {
                                    if (budEl.TryGetDouble(out var d))
                                        p.projectBudget = (decimal)d;
                                }
                                else if (budEl.ValueKind == System.Text.Json.JsonValueKind.String)
                                {
                                    if (decimal.TryParse(budEl.GetString(), out var parsed))
                                        p.projectBudget = parsed;
                                }
                            }

                            // optional status
                            if (dict.TryGetValue("status", out var stEl) && stEl.ValueKind != System.Text.Json.JsonValueKind.Null)
                                p.projectStatus = stEl.GetString();
                        }

                        results.Add(p);
                    }
                    catch (Exception exInner)
                    {
                        System.Diagnostics.Debug.WriteLine($"Map project item failed: {exInner}");
                    }
                }

                return results;
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"GetProjectsAsync failed: {ex}");
                // rethrow so callers can show error to user / debug
                throw;
            }
        }

        public async Task AddExpenseAsync(Expense exp)
        {
            try
            {
                await client.Child("expenses").PostAsync(exp);
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"AddExpenseAsync failed: {ex}");
                throw;
            }
        }

        /// <summary>
        /// Quick connectivity check to the Realtime Database root.
        /// Useful for surfacing connectivity / permission issues.
        /// </summary>
        public async Task<bool> TestConnectionAsync()
        {
            try
            {
                using var http = new System.Net.Http.HttpClient();
                http.Timeout = TimeSpan.FromSeconds(10);
                var url = BaseUrl.TrimEnd('/') + "/.json";
                var res = await http.GetAsync(url);
                var ok = res.IsSuccessStatusCode;
                System.Diagnostics.Debug.WriteLine($"TestConnectionAsync GET {url} -> {(int)res.StatusCode}");
                return ok;
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"TestConnectionAsync failed: {ex}");
                return false;
            }
        }
    }
}
    